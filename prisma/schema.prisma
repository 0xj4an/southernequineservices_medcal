generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Medication {
  id                String   @id @default(uuid())
  name              String
  category          String
  doseMin           Float
  doseMax           Float
  concentration     Float
  concentrationUnit String   @default("mg/ml")
  route             String
  notes             String?
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CriMedication {
  id                String   @id @default(uuid())
  name              String
  category          String
  loadingDoseMin    Float
  loadingDoseMax    Float
  rateMin           Float
  rateMax           Float
  rateUnit          String
  concentration     Float
  concentrationUnit String   @default("mg/ml")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
