generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Medication {
  id                String   @id @default(uuid())
  name              String
  category          String
  doseMin           Float
  doseMax           Float
  concentration     Float
  concentrationUnit String   @default("mg/ml")
  route             String
  notes             String?
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model MedicationRecord {
  id            String   @id @default(uuid())
  surgeonName   String
  horseName     String
  procedureName String
  weightKg      Float
  protocol      Json
  createdAt     DateTime @default(now())
}

model Procedure {
  id        String   @id @default(uuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CriMedication {
  id                String   @id @default(uuid())
  name              String
  category          String
  loadingDoseMin    Float
  loadingDoseMax    Float
  rateMin           Float?
  rateMax           Float?
  rateUnit          String?
  concentration     Float
  concentrationUnit String   @default("mg/ml")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
